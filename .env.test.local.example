# Supabase test project — copy this to .env.test.local and fill in real values.
# .env.test.local is gitignored (covered by .env*).

# Supabase URL of the dedicated test project (NOT prod).
E2E_SUPABASE_URL=https://YOUR-TEST-REF.supabase.co

# anon public key of the test project. Used by the Next.js app booted by
# Playwright via the webServer.env config.
E2E_SUPABASE_ANON_KEY=eyJhbGciOi...replace-me

# service_role secret key of the test project. Used by E2E test setup
# (creating users, seeding categories/products, cleanup) — never bundled.
E2E_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...replace-me

# Test user credentials. Created during setup. Must have role='admin'
# in user_profiles.
E2E_ADMIN_EMAIL=admin@blu-test.local
E2E_ADMIN_PASSWORD=ChangeMe-StrongPassword-1
